{
  "name": "meeting-slot-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "worker:dev": "tsx watch src/jobs/worker.ts",
    "build": "tsc -p tsconfig.json",
    "vercel-build": "npm run prisma:generate:vercel && npm run build",
    "start": "node dist/server.js",
    "worker:start": "node dist/jobs/worker.js",
    "prisma:generate": "prisma generate --schema ../database/prisma/schema.prisma",
    "prisma:generate:vercel": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema ../database/prisma/schema.prisma",
    "prisma:seed": "tsx ../database/prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.14.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.71.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "nodemailer": "^8.0.4",
    "prisma": "^6.14.0",
    "socket.io": "^4.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
